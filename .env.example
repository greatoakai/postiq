# ─────────────────────────────────────────────
# PostIQ — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to ".env" and fill in the blanks.
# Never commit the real .env file to git.

# ── TherapyAppointment Credentials ────────────
# The dedicated PostIQ login for TherapyAppointment.
# This must be a real TA user with permission to post payments.
TA_USERNAME=
TA_PASSWORD=

# ── PostIQ Settings ───────────────────────────
# HEADLESS=true → browser runs in the background (use for unattended runs)
# HEADLESS=false → visible browser window (use for debugging)
HEADLESS=true

# Log verbosity (INFO is the standard).
LOG_LEVEL=INFO

# ── AWS S3 ────────────────────────────────────
# PostIQ downloads new Square payment CSVs from S3 each morning.
# These credentials need read + delete access to the S3_BUCKET.
# (Use the same IAM user as the Square Daily Report project — they share the bucket.)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# The S3 bucket the Square Daily Report bot uploads to.
S3_BUCKET=greatoak-square-reports

# AWS region for the bucket.
S3_REGION=us-east-1

# Path inside the bucket where new CSVs land.
# Trailing slash is required.
S3_PREFIX=uploads/
